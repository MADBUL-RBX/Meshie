})

local function OverlayGUIParent(parent)
	OverlayHandles.Parent = parent
	OverlayArcHandles.Parent = parent
	OverlaySelectionBox.Parent = parent
	OverlaySurfaceSelection.Parent = parent
end


local function WrapOverlay(object, isbb, min_size)
	if type(object) == 'table' then
		if #object > 0 then
			local size, pos, parts = GetBoundingBox(object, true)
			if min_size and size.magnitude < min_size.magnitude then
				Overlay.Size = min_size
			else
				Overlay.Size = size
			end
			Overlay.CFrame = cf(pos)
			OverlayGUIParent(CoreRoot)
			return size,pos,parts
		else
			OverlayGUIParent(nil)
		end
	elseif not object then
		OverlayGUIParent(nil)
	elseif IsA(object,'BasePart') then
		if isbb then
			local size,pos,parts = GetBoundingBox({object},true)
			pos = cf(pos)
			if min_size and size.magnitude < min_size.magnitude then
				Overlay.Size = min_size
			else
				Overlay.Size = size
			end
			Overlay.CFrame = pos
			OverlayGUIParent(CoreRoot)
			return size,pos,parts
		else
			local size,pos = object.Size,object.CFrame
			if min_size and size.magnitude < min_size.magnitude then
				Overlay.Size = min_size
			else
				Overlay.Size = size
			end
			Overlay.CFrame = pos
			OverlayGUIParent(CoreRoot)
			return size,pos
		end
	end
end


local function SetOverlaySize(size)
	local cfr = Overlay.CFrame
	Overlay.Size = size
	Overlay.CFrame = cfr
end


local function SetOverlay(size, cfr)
	Overlay.Size, Overlay.CFrame = size, cfr
end


local function InSelection(object)
	if object then
		local objects = Selection:Get()
		for i = 1, #objects do
			if objects[i] == object then
				return true
			end
		end
	end
	return false
end


local function SelectionAdd(object)
	if not object or InSelection(object) then
		return
	end
	local objects = Selection:Get()
	objects[#objects + 1] = object
	Selection:Set(objects)
end


local table_remove = table.remove
local function SelectionRemove(object)
	local objects = Selection:Get()
	for i = 1, #objects do
		if objects[i] == object then
			table_remove(objects, i)
			Selection:Set(objects)
			return
		end
	end
	Selection:Set(objects)
end


local IsCtrlDown, IsAltDown, IsShiftDown do
	local ikd = InputService.IsKeyDown
	
	local ctrl_l, ctrl_r = Enum.KeyCode.LeftControl, Enum.KeyCode.RightControl
	local alt_l, alt_r = Enum.KeyCode.LeftAlt, Enum.KeyCode.RightAlt
	local shift_l, shift_r = Enum.KeyCode.LeftShift, Enum.KeyCode.RightShift
	
	function IsCtrlDown()
		return ikd(InputService, ctrl_l) or ikd(InputService, ctrl_r)
	end
	
	function IsAltDown()
		return ikd(InputService, alt_l) or ikd(InputService, alt_r)
	end
	
	function IsShiftDown()
		return ikd(InputService, shift_l) or ikd(InputService, shift_r)
	end
end

local ModelScope = workspace

local function GetTop(object,scope)
	if not object or object.Locked or not object:IsDescendantOf(scope) then
		return nil
	end
	local top = object
	repeat
		top = top.Parent
		if not top then
			return object
		end
	until top.Parent == scope
	return top
end


local GetTarget do
	local workspace = workspace
	local camera  = workspace.CurrentCamera
	local terrain = workspace.Terrain

	workspace:GetPropertyChangedSignal'CurrentCamera':Connect(function()
		local _camera = workspace.CurrentCamera
		if _camera then
			camera = _camera
		end
	end)
	
	workspace:GetPropertyChangedSignal'Terrain':Connect(function()
		terrain = workspace.Terrain
	end)

	local ray = Ray.new
	
	function GetTarget()		
		local mousePos = InputService:GetMouseLocation()
		local ray = camera:ViewportPointToRay(mousePos.x, mousePos.y)

		local origin = ray.Origin
		local unitDirection = ray.Direction.Unit
		local distance = 15000
		
		local params = RaycastParams.new()
		params.FilterDescendantsInstances = {Overlay, terrain}
		params.FilterType = Enum.RaycastFilterType.Blacklist
		params.BruteForceAllSlow = true
		params.IgnoreWater = true
		
		local result = workspace:Raycast(origin, unitDirection*distance, params)
		local pos = if result then result.Position else origin + unitDirection*distance
		local hit = if result then result.Instance else nil
		
		return hit, pos
	end
end


local function DoubleClick(Mouse)
	if InputService:IsKeyDown(DIRECT_SELECTION_KEY) then
		local Target = GetTarget()
		ModelScope = (Target and Target.Parent) or workspace
		DisplayInfo(false, 'Scope jump to: ', ModelScope:GetFullName())
		Selection:Set({Target})
	else
		local Target = GetTop(GetTarget(), ModelScope)
		if Target then
			if IsA(Target, 'Model') or IsA(Target, 'Folder') then
				Selection:Set({})
				ModelScope = Target
				DisplayInfo(false, 'Scope into: ', ModelScope:GetFullName())
			end
		elseif ModelScope:IsDescendantOf(workspace) then
			Selection:Set({ModelScope})
			ModelScope = ModelScope.Parent
			DisplayInfo(false, 'Scope out to: ', ModelScope:GetFullName())
		end
	end
end


local LastTarget = nil
local function Click(Mouse,first,remov)
	local Target
	if IsCtrlDown() and InputService:IsKeyDown(DIRECT_SELECTION_KEY) then
		Target = GetTarget()
	else
		Target = GetTop(GetTarget(), ModelScope)
	end
	if first then
		LastTarget = Target
		if Target then
			if IsCtrlDown() then
				if InSelection(Target) then
					SelectionRemove(Target)
					return true
				else
					SelectionAdd(Target)
					return false
				end
			else
				Selection:Set({Target})
			end
		else
			Selection:Set({})
		end
	else
		if Target ~= LastTarget then
			LastTarget = Target
			if IsCtrlDown() then
				if Target then
					if remov then
						SelectionRemove(Target)
					else
						SelectionAdd(Target)
					end
				end
			else
				Selection:Set({Target})
			end
		end
	end
end

local Mouse_Active = false

local PreviousTool = nil
local SelectedTool = nil

local ToolSelection = {}
local ToolModelSelection = {}

local MenuList = {}
local Menus = {}
local Variables = {}

local OnToolSelect = {}
local OnSelectionChanged = {}
local OnToolDeselect = {}

local ToolSelectCallback = {}
local SelectionChangedCallback = {}
local ToolDeselectCallback = {}

local BindToSelectionChanged do -- Prevents studio from hanging on Ctrl-A due to incremental selection update
	local frameBind
	if RunService:IsServer() and not RunService:IsClient() then
		frameBind = RunService.Stepped
	else
		frameBind = RunService.RenderStepped
	end

	local d0 = true
	local d1 = true
	
	frameBind:Connect(function()
		d0 = true
		d1 = true
	end)

	function BindToSelectionChanged(listener)
		return Selection.SelectionChanged:Connect(function()
			if d0 then
				d0 = false
				listener()
			elseif d1 then
				d1 = false
				frameBind:Wait()
				listener()
			end
		end)
	end
end

BindToSelectionChanged(function()
	if SelectedTool then
		local callback = SelectionChangedCallback[SelectedTool]
		if callback then
			callback()
		end
		local func = OnSelectionChanged[SelectedTool]
		if func then
			func(SelectedTool, Variables[SelectedTool])
		end
	end
end)

local function DeselectTool(tool)
	if tool then
		if ToolDeselectCallback[tool] then 
			ToolDeselectCallback[tool]()
		end

		local func = OnToolDeselect[tool]
		if func then 
			func(tool, Variables[tool])
		end
		PreviousTool = tool
		SelectedTool = nil
	end
end


local ActivateMouse

local function SelectTool(tool)
	if tool then
		if not Mouse_Active then
			ActivateMouse()
		end
		if SelectedTool then
			if SelectedTool == tool then
				DeselectTool(SelectedTool)
				return
			else 
				DeselectTool(SelectedTool)
			end
		end
		SelectedTool = tool

		if ToolSelectCallback[tool] then 
			ToolSelectCallback[tool]()
		end
		if SelectionChangedCallback[tool] then 
			SelectionChangedCallback[tool]()
		end
		OnToolSelect[tool](tool,Variables[tool])

		local func = OnSelectionChanged[tool]
		if func then
			func(tool,Variables[tool])
		end
	end
end


local function SelectPreviousTool()
	SelectTool(PreviousTool)
end


function ActivateMouse()
	Mouse_Active = true
	plugin:Activate(true)
	local Mouse = plugin:GetMouse()
	
	ModelScope = workspace

	local Down = false
	
	local select_hold = true
	local click_stamp = 0
	
	Event.Mouse.Move = Mouse.Move:Connect(function()
		click_stamp = 0
	end)
	
	Event.Mouse.Down = Mouse.Button1Down:Connect(function()
		Down = true
		if not IsAltDown() then
			local stamp = tick()
			if (stamp - click_stamp) < DOUBLE_CLICK_SPEED then
				DoubleClick(Mouse)
			else
				local remove = Click(Mouse, true)
				if select_hold then
					Event.Mouse.SelectHold = Mouse.Move:Connect(function()
						Click(Mouse, false, remove)
					end)
				end
			end
			click_stamp = stamp
		end
	end)
	
	Event.Mouse.Up = Mouse.Button1Up:Connect(function()
		Down = false
		Event.Mouse.SelectHold = nil
	end)
	
	Event.Mouse.Move = Mouse.Move:Connect(function()
		click_stamp = 0
	end)
end



local function DeactivateMouse()
	--[[for _, Item in next,Event.Mouse do
		Item:Disconnect()
	end--]]
	--Event.Mouse = {}
	Mouse_Active = false
	if SelectedTool then
		DeselectTool(SelectedTool)
	end
end


local mousebutton3 = Enum.UserInputType.MouseButton3




------------------------------ Tools -------------------------------------------------------------------------------------------


----------------------------------------------------------------------------------------------
------------------------------------------------------------------------------------------ Move
----------------------------------------------------------------------------------------------

do
	local Menu = 'Move'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			Increment = 1;
		};
		VariableList = {
			{'Increment','Move Increment'};
		};
		Color = rgb(255, 113, 65);
	}

	do
		local Tool = 'MoveAxis'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables

		local deselectCallback
		
		OnToolSelect[Tool] = function(tool,vars)
			OverlayHandles.Color = BrickColor.new('Bright orange')
			OverlayHandles.Style = 'Resize' --'Movement'
			OverlayHandles.Visible = true
		
			local origin = {}
			local modelOrigin = {}
			local ocf = Overlay.CFrame
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
			
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				inc = vars.Increment
				for k in next,origin do
					origin[k] = nil
				end
				for k in next,modelOrigin do
					modelOrigin[k] = nil
				end
				
				last_rdis = 0
				DisplayInfo(true, Menu, 0)
				for _,part in next, ToolSelection do
					origin[part] = part.CFrame
				end
				pcall(function()
					for _,model in next, ToolModelSelection do
						modelOrigin[model] = model:GetPivot()
					end
				end)
				ocf = Overlay.CFrame
				rdis = 0
				
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face,distance)
				rdis = Snap(distance,inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				local pos = nid(face)*rdis
				for part,cframe in next,origin do
					part.CFrame = cframe + pos
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = pivot + pos
				end
				Overlay.CFrame = ocf+pos
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection,true)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
		end
	end



	do
		local Tool = 'MoveObject'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables

		local deselectCallback
		
		OnToolSelect[Tool] = function(tool,vars)			
			OverlayHandles.Color = BrickColor.new('Bright orange')
			OverlayHandles.Style = 'Resize'
			OverlayHandles.Visible = true
		
			local origin = {}
			local ocf = Overlay.CFrame
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
			
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				inc = vars.Increment
				for k in next,origin do
					origin[k] = nil
				end
				last_rdis = 0
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					origin[part] = part.CFrame
				end
				ocf = Overlay.CFrame
				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face,distance)
				rdis = Snap(distance,inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				local vec = nid(face)*rdis
				local cfr = cf(vec)
				for part,cframe in next,origin do
					part.CFrame = cframe * cfr
				end
				Overlay.CFrame = ocf*cfr
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1])
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
		end
	end
	
	do
		local Tool = 'MoveFirst'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables

		local deselectCallback
		local pfc

		OnToolSelect[Tool] = function(tool,vars)
			
			OverlayHandles.Color = BrickColor.new('Bright orange')
			OverlayHandles.Style = 'Resize'
			OverlayHandles.Visible = true
		
			local origin = {}
			local modelOrigin = {}
			local corigin
			local ocf = Overlay.CFrame
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
			
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				inc = vars.Increment
				last_rdis = 0
				corigin = pfc and pfc.CFrame or ToolSelection[1].CFrame
				for k in next,origin do
					origin[k] = nil
				end
				for k in next,modelOrigin do
					modelOrigin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					origin[part] = corigin:toObjectSpace(part.CFrame)
				end
				pcall(function()
					for _,model in next, ToolModelSelection do
						modelOrigin[model] = corigin:toObjectSpace(model:GetPivot())
					end
				end)
				ocf = corigin:toObjectSpace(Overlay.CFrame)
				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face,distance)
				rdis = Snap(distance,inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				local cfr = corigin * cf(nid(face)*rdis)
				for part,cframe in next,origin do
					part.CFrame = cfr:toWorldSpace(cframe)
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = cfr:toWorldSpace(pivot)
				end
				Overlay.CFrame = cfr:toWorldSpace(ocf)
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
			
			Event[tool].Button3Down = InputService.InputBegan:Connect(function(input, gpe)
				if not gpe and input.UserInputType == mousebutton3 then
					local target = GetTarget()
					pfc = (pfc ~= target) and target or nil
					local selection, modelSelection = GetPartsAndModels(Selection:Get())
					ToolSelection = selection
					ToolModelSelection = modelSelection
					WrapOverlay(pfc or selection[1])
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			pfc = nil
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1])
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
			pfc = nil
		end
	end
end

----------------------------------------------------------------------------------------------
------------------------------------------------------------------------------------------ Rotate
----------------------------------------------------------------------------------------------

do
	local Menu = 'Rotate'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			Increment = 15;
		};
		VariableList = {
			{'Increment','Rotation Increment'};
		};
		Color = rgb(164, 189, 71);
	}

	local axis_x = Enum.Axis.X
	local axis_y = Enum.Axis.Y
	
	local EulerXYZ = CFrame.Angles
	
	local function RotX(theta)
		return EulerXYZ(theta, 0, 0)
	end
	
	local function RotY(theta)
		return EulerXYZ(0, theta, 0)
	end
	
	local function RotZ(theta)
		return EulerXYZ(0, 0, theta)
	end


	do
		local Tool = 'RotatePivot'
		
		table.insert(Menus['Rotate'].Tools,Tool)
		Variables[Tool] = Menus['Rotate'].Variables

		local min_size = v3(4,4,4)
		local deselectCallback
		local pfc

		OnToolSelect[Tool] = function(tool,vars)
			OverlayArcHandles.Color = BrickColor.new('Br. yellowish green')
			OverlayArcHandles.Visible = true
		
			
			local origin = {}
			local modelOrigin = {}
			local corigin
			local ocf
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
		
			Event[tool].Down = OverlayArcHandles.MouseButton1Down:Connect(function(axis)
				inc = vars.Increment
				corigin = pfc and pfc.CFrame or ToolSelection[1].CFrame
				for k in next,origin do
					origin[k] = nil
				end
				for k in next,modelOrigin do
					modelOrigin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _, part in next, ToolSelection do
					origin[part] = corigin:toObjectSpace(part.CFrame)
				end
				pcall(function()
					for _,model in next, ToolModelSelection do
						modelOrigin[model] = corigin:toObjectSpace(model:GetPivot())
					end
				end)
				ocf = corigin:toObjectSpace(Overlay.CFrame)
				
				rdis = 0
				last_rdis = 0
				function deselectCallback()
				end
			end)

			Event[tool].Drag = OverlayArcHandles.MouseDrag:Connect(function(axis,angle)
				rdis = Snap(deg(nmin(angle%tau,angle%-tau)),inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				local new
				if axis==axis_x then
					new=corigin*RotX(rad(rdis))
				elseif axis==axis_y then
					new=corigin*RotY(rad(rdis))
				else
					new=corigin*RotZ(rad(rdis))
				end
				for part,cframe in next,origin do
					part.CFrame = new:toWorldSpace(cframe)
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = new:toWorldSpace(pivot)
				end
				Overlay.CFrame = new:toWorldSpace(ocf)
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayArcHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)

			Event[tool].Button3Down = InputService.InputBegan:Connect(function(input, gpe)
				if not gpe and input.UserInputType == mousebutton3 then
					local target = GetTarget()
					pfc = (pfc ~= target) and target or nil
					local selection, modelSelection = GetPartsAndModels(Selection:Get())
					ToolSelection = selection
					ToolModelSelection = modelSelection
					WrapOverlay(pfc or selection[1],false,min_size)
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			pfc = nil
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1],false,min_size)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayArcHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
			pfc = nil
		end
	end
	
	do
		local Tool = 'RotateGroup'
		
		table.insert(Menus['Rotate'].Tools,Tool)
		Variables[Tool] = Menus['Rotate'].Variables
		
		local min_size = v3(4,4,4)
		local deselectCallback
		
		OnToolSelect[Tool] = function(tool,vars)
			OverlayArcHandles.Color = BrickColor.new('Br. yellowish green')
			OverlayArcHandles.Visible = true
		
			local origin = {}
			local modelOrigin = {}
			local corigin = Overlay.CFrame
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
		
			Event[tool].Down = OverlayArcHandles.MouseButton1Down:Connect(function(axis)
				inc = vars.Increment
				corigin = Overlay.CFrame
				for k in next,origin do
					origin[k] = nil
				end
				for k in next,modelOrigin do
					modelOrigin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					origin[part] = corigin:toObjectSpace(part.CFrame)
				end
				pcall(function()
					for _,model in next, ToolModelSelection do
						modelOrigin[model] = corigin:toObjectSpace(model:GetPivot())
					end
				end)

				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayArcHandles.MouseDrag:Connect(function(axis,angle)
				rdis = Snap(deg(nmin(angle%tau,angle%-tau)),inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				
				local new;
				if axis==axis_x then
					new=corigin*RotX(rad(rdis))
				elseif axis==axis_y then
					new=corigin*RotY(rad(rdis))
				else
					new=corigin*RotZ(rad(rdis))
				end
				for part,cframe in next,origin do
					part.CFrame = new:toWorldSpace(cframe)
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = new:toWorldSpace(pivot)
				end
				Overlay.CFrame = new
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayArcHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(ToolSelection,true,min_size)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayArcHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
		end
	end

	do
		local Tool = 'RotateObject'
		
		table.insert(Menus['Rotate'].Tools,Tool)
		Variables[Tool] = Menus['Rotate'].Variables
		
		local min_size = v3(4,4,4)
		local deselectCallback

		OnToolSelect[Tool] = function(tool,vars)
			OverlayArcHandles.Color = BrickColor.new('Br. yellowish green')
			OverlayArcHandles.Visible = true
		
			local origin = {}
			local modelOrigin = {}
			local ocf = Overlay.CFrame
			local inc = vars.Increment
			local rdis = 0
			local last_rdis = 0
		
			Event[tool].Down = OverlayArcHandles.MouseButton1Down:Connect(function(axis)
				inc = vars.Increment
				for k in next,origin do
					origin[k] = nil
				end
				for k in next,modelOrigin do
					modelOrigin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					origin[part] = part.CFrame
				end
				pcall(function()
					for _,model in next, ToolModelSelection do
						modelOrigin[model] = model:GetPivot()
					end
				end)
				ocf = Overlay.CFrame
				
				
				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayArcHandles.MouseDrag:Connect(function(axis,angle)
				rdis = Snap(deg(nmin(angle%tau,angle%-tau)),inc)
				if last_rdis == rdis then return end
				last_rdis = rdis
				local new
				if axis==axis_x then
					new=RotX(rad(rdis))
				elseif axis==axis_y then
					new=RotY(rad(rdis))
				else
					new=RotZ(rad(rdis))
				end
				for part,cframe in next,origin do
					part.CFrame = cframe*new
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = pivot*new
				end
				Overlay.CFrame = ocf*new
				DisplayInfo(false, Menu, rdis)
			end)
			
			Event[tool].Up = OverlayArcHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1],false,min_size)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayArcHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
		end
	end
end

----------------------------------------------------------------------------------------------
------------------------------------------------------------------------------------------ Resize
----------------------------------------------------------------------------------------------

do
	local Menu = 'Resize'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			Increment = 1;
		};
		VariableList = {
			{'Increment','Resize Increment'};
		};
		Color = rgb(4, 175, 236);
	}

	local FACE_MULTIPLIER = {
		[Enum.NormalId.Back]	=  1;
		[Enum.NormalId.Right]	=  1;
		[Enum.NormalId.Top]		=  1;
		[Enum.NormalId.Bottom]	= -1;
		[Enum.NormalId.Front]	= -1;
		[Enum.NormalId.Left]	= -1;
	}
	
	local FACE_COMPONENT = {
		[Enum.NormalId.Left]	= 'x';
		[Enum.NormalId.Right]	= 'x';
		[Enum.NormalId.Bottom]	= 'y';
		[Enum.NormalId.Top]		= 'y';
		[Enum.NormalId.Back]	= 'z';
		[Enum.NormalId.Front]	= 'z';
	}

	do
		local Tool = 'ResizeObject'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables
		
		local deselectCallback

		local origin = {}
		
		OnToolSelect[Tool] = function(tool,vars)
			OverlayHandles.Color = BrickColor.new('Cyan')
			OverlayHandles.Style = 'Resize'
			OverlayHandles.Visible = true
		
			local first
			local face_mult,face_size,face_vec
			local cinc
			local inc
			local rdis = 0
			local last_dist = 0
			
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				last_dist = 0
				face_mult,face_size,face_vec = FACE_MULTIPLIER[face],FACE_COMPONENT[face],nid(face)
				first = ToolSelection[1]
				for k in next,origin do
					origin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _,part in next, ToolSelection do
					if not IsA(part, 'Terrain') then
						local isTruss = IsA(part, 'TrussPart')
						origin[part] = {
							part.CFrame,
							part.Size,
							isTruss,
							isTruss and 2 or MIN_SIZE
						}
					end
				end
				cinc = vars.Increment
				inc = Snap(cinc,1)
				if inc == 0 then
					inc = 1
				end
				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face,distance)
				local dis = distance*face_mult
				local ddis = Snap(dis, cinc)
				if ddis == last_dist then
					return
				end
				last_dist = ddis
				for part,info in next,origin do
					local sz,isTruss,ffm = info[2],info[3],info[4]
					local mult = isTruss and Snap(dis, inc*ffm) or ddis
					local fsize = sz[face_size]
					local mod = fsize + mult*face_mult < ffm and face_vec*((ffm - fsize)*face_mult) or face_vec*mult
					part.Size = sz + mod
					part.CFrame = info[1]*cf(mod*face_mult/2)
					if part == first then
						rdis = mod.magnitude
						DisplayInfo(false, Menu, rdis)
					end
				end
				SetOverlay(first.Size,first.CFrame)
			end)
			
			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1],false)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
			for k in next, origin do
				origin[k] = nil
			end
		end
	end

	do
		local Tool = 'ResizeCenter'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables
		
		local deselectCallback
		local origin = setmetatable({}, {__mode='k'})
		local first

		OnToolSelect[Tool] = function(tool,vars)
			OverlayHandles.Color = BrickColor.new('Cyan')
			OverlayHandles.Style = 'Resize'
			OverlayHandles.Visible = true
		

			local face_mult,face_size,face_vec
			local cinc
			local inc
			local lastDist = 0
			local rdis = 0
		
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				lastDist = 0
				face_mult,face_size,face_vec = FACE_MULTIPLIER[face],FACE_COMPONENT[face],nid(face)
				first = ToolSelection[1]
				for k in next,origin do
					origin[k] = nil
				end
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					if not IsA(part, 'Terrain') then
						local isTruss = IsA(part, 'TrussPart')
						origin[part] = {
							part.Size,
							isTruss,
							isTruss and 2 or MIN_SIZE
						}
					end
				end
				cinc = vars.Increment
				inc = Snap(cinc,1)
				if inc == 0 then
					inc = 1
				end
				
				rdis = 0
				function deselectCallback()
				end
			end)
			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face,distance)
				if face_mult then
					local dis = distance*face_mult
					local ddis = Snap(dis, cinc)
					if ddis == lastDist then
						return
					end
					lastDist = ddis
					for part,info in next,origin do
						local sz,isTruss,ffm = info[1],info[2],info[3]	
						local mult = isTruss and Snap(dis, inc*ffm) or ddis
						local fsize = sz[face_size]
						local mod = fsize + mult*face_mult < ffm and face_vec*((ffm-fsize)*face_mult) or face_vec*mult
						part.Size = sz + mod
						if part == first then
							rdis = mod.magnitude
							DisplayInfo(false, Menu, rdis)
						end
					end
					SetOverlay(first.Size,first.CFrame)
				end
			end)

			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1],false)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
			first = nil
			for k in next, origin do
				origin[k] = nil
			end
		end
	end

	do
		local Tool = 'ResizeWorld'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables
		
		local deselectCallback

		local origin = {}
		
		local faceList = {
			Enum.NormalId.Back;
			Enum.NormalId.Bottom;
			Enum.NormalId.Front;
			Enum.NormalId.Left;
			Enum.NormalId.Right;
			Enum.NormalId.Top;
		}
		local faceVectors = {}
		for index, face in next, faceList do
			faceVectors[index] = nid(face)
		end
		
		OnToolSelect[Tool] = function(tool,vars)
			OverlayHandles.Color = BrickColor.new('Cyan')
			OverlayHandles.Style = 'Resize'
			OverlayHandles.Visible = true
		
			local first
			local cinc
			local inc
			local rdis = 0
			local lastDist = 0
			local fNorm
			
			Event[tool].Down = OverlayHandles.MouseButton1Down:Connect(function(face)
				lastDist = 0
				first = ToolSelection[1]
				for k in next,origin do
					origin[k] = nil
				end
				fNorm = first.CFrame:vectorToWorldSpace(nid(face))
				DisplayInfo(true, Menu, 0)
				for _,part in next,ToolSelection do
					if not IsA(part, 'Terrain') then
						local partCFrame = part.CFrame
						local rIndex, rDot = 1, -inf
						for i, test in next, faceVectors do
							local td = part.CFrame:vectorToWorldSpace(test):Dot(fNorm)
							if td > rDot then
								rDot = td
								rIndex = i
							end
						end
						local faceObj = faceList[rIndex]
						local isTruss = IsA(part, 'TrussPart')
						origin[part] = {
							partCFrame;
							part.Size;
							isTruss;
							isTruss and 2 or MIN_SIZE;
							FACE_MULTIPLIER[faceObj];
							FACE_COMPONENT[faceObj];
							faceVectors[rIndex];
						}
					end
				end
				cinc = vars.Increment
				inc = Snap(cinc,1)
				if inc == 0 then
					inc = 1
				end

				rdis = 0
				function deselectCallback()
				end
			end)

			
			Event[tool].Drag = OverlayHandles.MouseDrag:Connect(function(face, distance)
				local ddis = Snap(distance, cinc)
				if ddis == lastDist then
					return
				end
				lastDist = ddis
				for part, info in next, origin do
					local sz, isTruss, ffm, face_mult, face_size, face_vec = info[2], info[3], info[4], info[5], info[6], info[7]
					local dis = distance*face_mult
					local mult = Snap(dis, isTruss and inc*ffm or cinc)
					local fsize = sz[face_size]
					local mod = fsize + mult*face_mult < ffm and face_vec*((ffm - fsize)*face_mult) or face_vec*mult
					part.Size = sz + mod
					part.CFrame = info[1]*cf(mod*face_mult/2)
					if part == first then
						rdis = mod.magnitude
						DisplayInfo(false, Menu, rdis)
					end
				end
				SetOverlay(first.Size,first.CFrame)
			end)
			
			Event[tool].Up = OverlayHandles.MouseButton1Up:Connect(function()
				if deselectCallback then
					deselectCallback()
					DisplayInfo(true, Menu .. 'd', rdis)
					deselectCallback = nil
				end
			end)
		end
		
		OnSelectionChanged[Tool] = function(tool,vars)
			local selection, modelSelection = GetPartsAndModels(Selection:Get())
			ToolSelection = selection
			ToolModelSelection = modelSelection
			WrapOverlay(selection[1],false)
		end
		
		OnToolDeselect[Tool] = function(tool,vars)
			Event[tool] = nil
			OverlayHandles.Visible = false
			if deselectCallback then
				deselectCallback()
			end
			for k in next, origin do
				origin[k] = nil
			end
		end
	end
end

