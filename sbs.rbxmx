					<ProtectedString name="Source"><![CDATA[local help = [[The following constants are defined in the SBS parametric evaluation environment:

- prev, last, x  |  Last value of the input box
- math.*         |  Lua math library
- e              |  Euler's number
- pi             |  Pi
- tau            |  Circumference of unit circle
- phi            |  The golden ratio
- invphi         |  1/phi
- feigenbaum_1   |  First Feigenbaum constant
- feigenbaum_2   |  Second Feigenbaum constant
- khinchin       |  Khinchin's constant
- glaisher       |  Glaisher's constant
- p2             |  Universal parabolic constant
]]

local env = {
	abs = math.abs; acos = math.acos; asin = math.asin; atan = math.atan;
	atan2 = math.atan2; ceil = math.ceil; cos = math.cos; cosh = math.cosh;
	deg = math.deg; exp = math.exp; floor = math.floor; fmod = math.fmod;
	frexp = math.frexp; huge = math.huge; ldexp = math.ldexp; log = math.log;
	log10 = math.log10; max = math.max; min = math.min; modf = math.modf;
	pow = math.pow; rad = math.rad; random = math.random; sin = math.sin;
	sinh = math.sinh; sqrt = math.sqrt; tan = math.tan; tanh = math.tanh;
	pi = math.pi;
	tau = 2*math.pi; 
	e = math.exp(1); 
	phi = (math.sqrt(5) + 1)/2;
	invphi = (math.sqrt(5) - 1)/2;
	feigenbaum_1 = 4.669201609102990;
	feigenbaum_2 = 2.502907875095892;
	khinchin = 2.6854520010;
	glaisher = 1.2824271291;
	p2 = 2.295587149392638;
	answer = 42;
	prev = 'prev';
	last = 'prev';
	x = 'prev';
}

return {help = help, env = env}]]></ProtectedString>
					<string name="ScriptGuid">{8B605446-1393-4C2B-B996-8969B96DF042}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">mathEnv</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXDD5631765EA549EC9B6D96E5C2F52336">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[-- spr: Spring animation library
-- Author: Parker Stebbins <parker@fractality.io>

local RunService = game:GetService('RunService')

local typeof = typeof
local pairs = pairs
local next = next

local pi = math.pi
local abs = math.abs
local exp = math.exp
local sin = math.sin
local cos = math.cos
local sqrt = math.sqrt
local floor = math.floor
local min = math.min

local LinearSpring = {} do
	LinearSpring.__index = LinearSpring
	
	local SLEEP_OFFSET_LIMIT = 1e-5^2
	local SLEEP_VELOCITY_LIMIT = 1e-6^2

	function LinearSpring.new(dampingRatio, frequency, pos, typedat)
		local linearPos = typedat.toIntermediate(pos)
		return setmetatable(
			{
				d = dampingRatio,
				f = frequency,
				g = linearPos,
				p = linearPos,
				v = linearPos*0,
				typedat = typedat,
			},
			LinearSpring
		)
	end

	function LinearSpring:setGoal(goal)
		self.g = self.typedat.toIntermediate(goal)
	end
	
	function LinearSpring:setSpringParams(dampingRatio, frequency)
		self.d = dampingRatio
		self.f = frequency
	end

	function LinearSpring:canSleep()
		local v = self.v:norm()
		local o = (self.p - self.g):norm()
		return v < SLEEP_VELOCITY_LIMIT and o < SLEEP_OFFSET_LIMIT
	end

	function LinearSpring:step(dt)
		local d = self.d
		local f = self.f*2*pi
		local g = self.g
		local p0 = self.p
		local v0 = self.v

		local o = p0 - g
		local decay = exp(-d*f*dt)

		local p1, v1

		if d == 1 then
			p1 = (o*(1 + f*dt) + v0*dt)*decay + g   -- v+v 2, v*s 3
			v1 = (v0*(1 - f*dt) - o*(f*f*dt))*decay -- v-v 1, v*s 3
			
		elseif d < 1 then
			local c = sqrt(1 - d*d)
			
			local i = cos(dt*f*c)
			local j = sin(dt*f*c)
			
			local y = j/(f*c)
			local z = j/c
			
			p1 = (o*(i + z*d) + v0*y)*decay + g -- v+v 2, v*s 3
			v1 = (v0*(i - z*d) - o*(z*f))*decay -- v-v 1, v*s 3
			
		else
			local c = sqrt(d*d - 1)

			local r1 = -f*(d - c)
			local r2 = -f*(d + c)
			
			local co2 = (v0 - o*r1)/(2*f*c)
			local co1 = o - co2

			local e1 = co1*exp(r1*dt)
			local e2 = co2*exp(r2*dt)

			p1 = e1 + e2 + g
			v1 = e1*r1 + e2*r2
		end

		self.p = p1
		self.v = v1

		return self.typedat.fromIntermediate(p1)
	end
end

local LinearValue = {} do
	LinearValue.__index = LinearValue
	
	local setmetatable = setmetatable
	local unpack = unpack

	function LinearValue.new(...)
		return setmetatable({...}, LinearValue)
	end

	function LinearValue:__add(rhs)
		local out = setmetatable({unpack(self)}, LinearValue)
		for i = 1, #out do
			out[i] = out[i] + rhs[i]
		end
		return out
	end
	
	function LinearValue:__sub(rhs)
		local out = setmetatable({unpack(self)}, LinearValue)
		for i = 1, #out do
			out[i] = out[i] - rhs[i] 
		end
		return out
	end

	function LinearValue:__mul(rhs)
		local out = setmetatable({unpack(self)}, LinearValue)
		for i = 1, #out do
			out[i] = out[i]*rhs
		end
		return out
	end

	function LinearValue:__div(rhs)
		local out = setmetatable({unpack(self)}, LinearValue)
		for i = 1, #out do
			out[i] = out[i]/rhs
		end
		return out
	end
	
	function LinearValue:norm()
		local out = 0
		for _, v in pairs(self) do
			out = out + v*v
		end
		return out
	end
end

local typeMetadata = {
	number = {
		springType = LinearSpring,
		toIntermediate = function(value)
			return LinearValue.new(value)
		end,
		fromIntermediate = function(value)
			return value[1]
		end,
	},

	NumberRange = {
		springType = LinearSpring,
		toIntermediate = function(value)
			return LinearValue.new(value.Min, value.Max)
		end,
		fromIntermediate = function(value)
			return NumberRange.new(value[1], value[2])
		end,
	},

	UDim = {
		springType = LinearSpring,
		toIntermediate = function(value)
			return LinearValue.new(value.Scale, value.Offset)
		end,
		fromIntermediate = function(value)
			return UDim.new(value[1], value[2])
		end,
	},

	UDim2 = {
		springType = LinearSpring,
		toIntermediate = function(value)
			local x = value.X
			local y = value.Y
			return LinearValue.new(x.Scale, x.Offset, y.Scale, y.Offset)
		end,
		fromIntermediate = function(value)
			return UDim2.new(value[1], floor(value[2] + 0.5), value[3], floor(value[4] + 0.5))
		end,
	},

	Vector2 = {
		springType = LinearSpring,
		toIntermediate = function(value)
			return LinearValue.new(value.X, value.Y)
		end,
		fromIntermediate = function(value)
			return Vector2.new(value[1], value[2])
		end,
	},

	Vector3 = {
		springType = LinearSpring,
		toIntermediate = function(value)
			return LinearValue.new(value.X, value.Y, value.Z)
		end,
		fromIntermediate = function(value)
			return Vector3.new(value[1], value[2], value[3])
		end,
	},

	Color3 = {
		springType = LinearSpring,
		toIntermediate = function(value)
			local r, g, b = value.r, value.g, value.b

			r = r < 0.0404482362771076 and r/12.92 or 0.87941546140213*(r + 0.055)^2.4
			g = g < 0.0404482362771076 and g/12.92 or 0.87941546140213*(g + 0.055)^2.4
			b = b < 0.0404482362771076 and b/12.92 or 0.87941546140213*(b + 0.055)^2.4

			local x = 0.9257063972951867*r - 0.8333736323779866*g - 0.09209820666085898*b
			local y = 0.2125862307855956*r + 0.71517030370341085*g + 0.0722004986433362*b
			local z = 3.6590806972265883*r + 11.4426895800574232*g + 4.1149915024264843*b

			local l = y > 0.008856451679035631 and 116*y^(1/3) - 16 or 903.296296296296*y
			local u, v
			if z > 1e-15 then
				u = l*x/z
				v = l*(9*y/z - 0.46832)
			else
				u = -0.19783*l
				v = -0.46832*l
			end

			return LinearValue.new(l, u, v)
		end,
		fromIntermediate = function(value)
			local l = value[1]
			if l < 0.0197955 then
				return Color3.new(0, 0, 0)
			end
			local u = value[2]/l + 0.19783
			local v = value[3]/l + 0.46832

			local y = (l + 16)/116
			y = y > 0.206896551724137931 and y*y*y or 0.12841854934601665*y - 0.01771290335807126
			local x = y*u/v
			local z = y*((3 - 0.75*u)/v - 5)

			local r =  7.2914074*x - 1.5372080*y - 0.4986286*z
			local g = -2.1800940*x + 1.8757561*y + 0.0415175*z
			local b =  0.1253477*x - 0.2040211*y + 1.0569959*z

			if r < 0 and r < g and r < b then
				r, g, b = 0, g - r, b - r
			elseif g < 0 and g < b then
				r, g, b = r - g, 0, b - g
			elseif b < 0 then
				r, g, b = r - b, g - b, 0
			end

			return Color3.new(
				min(r < 3.1306684425e-3 and 12.92*r or 1.055*r^(1/2.4) - 0.055, 1),
				min(g < 3.1306684425e-3 and 12.92*g or 1.055*g^(1/2.4) - 0.055, 1),
				min(b < 3.1306684425e-3 and 12.92*b or 1.055*b^(1/2.4) - 0.055, 1)
			)
		end,
	},
}

local springStates = {} -- {[instance] = {[property] = spring}

RunService.RenderStepped:Connect(function(dt)
	for instance, state in pairs(springStates) do
		for name, spring in pairs(state) do
			instance[name] = spring:step(dt)

			if spring:canSleep() then
				state[name] = nil
			end
		end

		if not next(state) then
			springStates[instance] = nil
		end
	end
end)

local spr = {} do
	function spr.target(instance, dampingRatio, frequency, properties)
		local state = springStates[instance]

		if not state then
			state = {}
			springStates[instance] = state
		end

		for name, goal in pairs(properties) do
			local spring = state[name]
			if not spring then
				local md = typeMetadata[typeof(goal)]
				spring = md.springType.new(dampingRatio, frequency, instance[name], md)
				state[name] = spring
			end
			
			spring:setSpringParams(dampingRatio, frequency)
			spring:setGoal(goal)
		end
	end

	function spr.stop(instance, property)
		if property then
			local state = springStates[instance]
			if state then
				state[property] = nil
			end
		else
			springStates[instance] = nil
		end
	end
end

return spr
]]></ProtectedString>
