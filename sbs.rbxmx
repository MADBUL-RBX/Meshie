do
	local Menu = 'Scale'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			Scale = 0.5;
		};
		VariableList = {
			{'Scale','Scale Factor'};
		};
		Color = rgb(168, 70, 217);
	}
	
	do
		local Tool = 'Scale'
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables
	
		local MinimumSizeV3 = v3(MIN_SIZE, MIN_SIZE, MIN_SIZE)	
		
		local function SetMeshId(Mesh, MeshPart)
			Mesh.MeshId = MeshPart.MeshId
		end
	
		local function GetMesh(Part, DoCreate)
			for _, Item in next, Children(Part) do
				if IsA(Item, 'DataModelMesh') then
					return Item
				end
			end
			local Mesh
			if DoCreate then
				if IsA(Part, 'Part') then
					local sn = Part.Shape.Name
					if sn == 'Block' then
						Mesh = inst('BlockMesh', Part)
					elseif sn == 'Cylinder' then
						Mesh = inst('SpecialMesh', Part)
						Mesh.MeshType = Enum.MeshType.Cylinder
					else
						Mesh = inst('SpecialMesh', Part)
						Mesh.MeshType = Enum.MeshType.Sphere
					end
				elseif IsA(Part, 'WedgePart') then
					Mesh = inst('SpecialMesh', Part)
					Mesh.MeshType = Enum.MeshType.Wedge
				elseif IsA(Part, 'CornerWedgePart') then
					Mesh = inst('SpecialMesh', Part)
					Mesh.MeshType = Enum.MeshType.CornerWedge
				elseif IsA(Part, 'Truss') or IsA(Part, 'VehicleSeat') then
					Mesh = inst('BlockMesh', Part)
				elseif IsA(Part, 'MeshPart') then
					Mesh = inst('FileMesh', Part)
					pcall(SetMeshId, Mesh, Part)
				end
			end
			return Mesh
		end	
		
		
		local function Resize(Part, NewSize)
			local Mesh = GetMesh(Part)
			local scaleFactor = NewSize/Part.Size
			if min(NewSize.x, NewSize.y, NewSize.z) < MIN_SIZE then
				Part.Size = MinimumSizeV3
				local Mesh = Mesh or GetMesh(Part, true)
				Mesh.Scale = NewSize/Part.Size*Mesh.Scale
			else
				if Mesh and (Mesh.ClassName == 'FileMesh' 
					or (Mesh.ClassName == 'SpecialMesh' and Mesh.MeshType == Enum.MeshType.FileMesh)) then
					Mesh.Scale = Mesh.Scale*scaleFactor
				end
				Part.Size = NewSize
			end
			if Mesh then
				Mesh.Offset = Mesh.Offset*scaleFactor
			end
		end
		
		
		local function ScaleModel(Bricks, Models, BaseCFrame, Scale)
			for _, Item in next, Bricks do
				local cfr = Item.CFrame
				if IsA(Item, 'PartOperation') then
					Item.Size = cfr:vectorToObjectSpace(
						BaseCFrame:vectorToWorldSpace(
							BaseCFrame:vectorToObjectSpace(
								cfr:vectorToWorldSpace(
									Item.Size
								)
							)*Scale
						)
					)
				else
					local NewSize = cfr:vectorToObjectSpace(
						BaseCFrame:vectorToWorldSpace(
							BaseCFrame:vectorToObjectSpace(
								cfr:vectorToWorldSpace(Item.Size)
							)*Scale
						)
					)
					Resize(Item, NewSize)
				end
				do
					local RelativeOffset = BaseCFrame:toObjectSpace(cfr)
					local x, y, z, xx, xy, xz, yx, yy, yz, zx, zy, zz = RelativeOffset:components()
					x, y, z = x*Scale.X, y*Scale.Y, z*Scale.Z
					local ScaledOffset = cf(x, y, z, xx, xy, xz, yx, yy, yz, zx, zy, zz)
					local Offset = BaseCFrame:toWorldSpace(ScaledOffset)
					Item.CFrame = Offset
				end
			end
			pcall(function()
				for _, Model in next, Models do
					local RelativeOffset = BaseCFrame:toObjectSpace(Model:GetPivot())
					local x, y, z, xx, xy, xz, yx, yy, yz, zx, zy, zz = RelativeOffset:components()
					x, y, z = x*Scale.X, y*Scale.Y, z*Scale.Z
					local ScaledOffset = cf(x, y, z, xx, xy, xz, yx, yy, yz, zx, zy, zz)
					local Offset = BaseCFrame:toWorldSpace(ScaledOffset)
					Model.WorldPivot = Offset
				end
			end)
		end
		
		local function resizeImplementation(modelList, resizeFactor)
			if not resizeFactor then
				resizeFactor = modelList
				modelList = Selection:Get()
			end
			for _, model in next,modelList do
				model:BreakJoints()
				local parts, models = GetPartsAndModels{model}
				local orient = model:GetModelCFrame()
				pcall(function()
					orient = model:GetPivot()
				end)
				ScaleModel(parts, models, orient, v3(resizeFactor,resizeFactor,resizeFactor))
				model:MakeJoints()
			end
			return modelList
		end
		
		OnToolSelect[Tool] = function(tool, vars)
			local copy = {}
			local copy_parent = {}
			local selection = Selection:Get()
			if #selection == 0 then
				DisplayInfo(false, 'Selection was empty')
				SelectPreviousTool()
				return
			end
			DisplayInfo(true)
			
			for _, v in next, selection do		
				local _, object = pcall(Clone, v)
				if object then
					copy[#copy + 1] = object
					copy_parent[object] = object.Parent
				end
			end
		
			local cSize,cPos,cParts = GetBoundingBox(copy,true)
			local sSize,sPos
			if #selection > 0 then
				sSize,sPos = GetBoundingBox(selection)
			else
				sSize,sPos = cSize,cPos
			end
		
			local center = cf(cPos)
			local new = cf(sPos)
		
			for i,part in next,cParts do
				part.CFrame = new:toWorldSpace(center:toObjectSpace(part.CFrame))
			end
		
			local NewModel = inst('Model', ModelScope)
			NewModel.Name = 'ScaledModel'
		
			for i,v in next,copy do
				v.Parent = copy_parent[v] or NewModel--ModelScope
			end
		
			resizeImplementation({NewModel}, vars.Scale)
			Selection:Set({NewModel})
			
			DisplayInfo(true, 'Scaled selection by a factor by '..vars.Scale)
			SelectPreviousTool()
		end
	end
end

