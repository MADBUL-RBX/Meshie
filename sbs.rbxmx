do
	local Menu = 'Convert'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			ClassName = 'WedgePart';
		};
		VariableList = {
			{'ClassName','Class name to convert to'};
		};
		Color = rgb(255, 107, 107);
	}
	do
		local Tool = 'Convert'
		
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables
	
	
		local function SetProperty(obj, target, prop)
			target[prop] = obj[prop]
		end
		
		local propertyList = {
			Instance = {
				'Name';
				'Parent';
				'Archivable';
			};
			BasePart = {
				'BrickColor';
				'Material';
				'Reflectance';
				'Transparency';
				'MeshID';
				'TextureID';
				'Anchored';
				'CanCollide'; 
				'Velocity';
				'RotVelocity';
				'Locked'; 
				'CustomPhysicalProperties';
				'BackParamA'; 
				'BackParamB'; 
				'BackSurfaceInput'; 
				'BottomParamA'; 
				'BottomParamB'; 
				'BottomSurfaceInput'; 
				'FrontParamA'; 
				'FrontParamB'; 
				'FrontSurfaceInput'; 
				'LeftParamA'; 
				'LeftParamB'; 
				'LeftSurfaceInput'; 
				'RightParamA'; 
				'RightParamB';
				'RightSurfaceInput'; 
				'TopParamA'; 
				'TopParamB'; 
				'TopSurfaceInput'; 
				'BackSurface'; 
				'BottomSurface'; 
				'FrontSurface'; 
				'LeftSurface'; 
				'RightSurface'; 
				'TopSurface';
			}
		}

		local function MoveDescendants(obj0, obj1)
			for _, v in next, Children(obj0) do
				v.Parent = obj1
			end
		end
		
		OnToolSelect[Tool] = function(tool, vars)
			local copy = {}
			local copy_parent = {}
			local selection = Selection:Get()
			if #selection == 0 then
				DisplayInfo(false, 'Selection was empty')
				SelectPreviousTool()
				return
			end
			DisplayInfo(true)
			local converted = false
		
			for _, v in next, selection do
				local isValid, object = pcall(inst, vars.ClassName)
				if isValid then
					if IsA(v, 'BasePart') then
						local PartProps = propertyList.BasePart
						if IsA(object, 'BasePart') then
							for Property = 1, #PartProps do
								pcall(SetProperty, v, object, PartProps[Property])
							end
							copy[#copy + 1] = object
							copy_parent[object] = v.Parent
			
							object.Size = v.Size
							object.CFrame = v.CFrame
			
							v:Destroy()
							converted = true
						else
							object:Destroy()
						end
					else
						PluginWarn('Converter cannot convert objects of class ' .. v.ClassName)
					end
				else
					PluginWarn('Could not convert because ' .. vars.ClassName .. ' is not a class.')
				end
			end
		
			for i,v in next,copy do
				v.Parent = copy_parent[v] or ModelScope
			end
		
			Selection:Set(copy)
			
			if converted then
				DisplayInfo(true, 'Successfully converted.')
			end
			SelectPreviousTool()
		end
	end
end

do
	local Menu = 'SelectEdge'
	table.insert(MenuList,Menu)
	Menus[Menu] = {
		Tools = {};
		Variables = {
			EdgeSnap = 0.5;
			RotIncrement = 5;
		};
		VariableList = {
			{'RotIncrement','Rotation Increment (In Degrees)'};
			{'EdgeSnap','Edge Snap (In Studs)'};
		};
		Color = rgb(245, 205, 48);
	}

	local function GetRelativeEdge(p,s,inc)
		local px, sx, py, sy, pz, sz = p.x, s.x, p.y, s.y, p.z, s.z
		local ax, ay, az = abs(px/sx), abs(py/sy), abs(pz/sz)
		return v3(
			(px > 0 and 1 or px < 0 and -1 or px)*((ax>ay or ax>az) and sx or Snap(abs(px), inc)),
			(py > 0 and 1 or py < 0 and -1 or py)*((ay>ax or ay>az) and sy or Snap(abs(py), inc)),
			(pz > 0 and 1 or pz < 0 and -1 or pz)*((az>ax or az>ay) and sz or Snap(abs(pz), inc))
		)
	end

	local function FilterTarget(target)
		if target and not target.Locked then
			return target
		else
			return nil
		end
	end

	do
		local Tool = 'SelectEdge'
		table.insert(Menus[Menu].Tools,Tool)
		Variables[Tool] = Menus[Menu].Variables

		local function SelectEdgeUpdateOverlay()
			local Size, Position = GetBoundingBox(ToolSelection)

			local PositionNumber = (Overlay.Position - Position).magnitude
			local SizeNumber = max(Size.X, Size.Y, Size.Z)/2

			if PositionNumber > SizeNumber then
				SizeNumber = PositionNumber
			end

			SizeNumber = min(25, max(2, SizeNumber))

			Overlay.Size = v3(SizeNumber, SizeNumber, SizeNumber)
		end




		OnToolSelect[Tool] = function(tool,vars)
			local Down = false
			local SelectEdgeVisible = false

			local select_hold = true
			local click_stamp = 0

			OverlayGUIParent(nil)
			OverlayArcHandles.Color   = BrickColor.new('Bright yellow')
			OverlaySelectionBox.Color = BrickColor.new('Bright yellow')

			DisplayInfo(false, 'Select Edge activated. Hold down [ALT] and press [MOUSE BUTTON 3] to select an edge.')

			local function select_edge()
				OverlayArcHandles.Visible = false
				OverlaySelectionBox.Visible = true
				Overlay.Size = v3(1,1,1)
				local Target, hit = GetTarget()
				Target = FilterTarget(Target)
				if Target then
					OverlayGUIParent(CoreRoot)
					local tcf = Target.CFrame
					local pos = tcf:toObjectSpace(cf(hit)).p
					local JointCenter = cf(GetRelativeEdge(pos,Target.Size/2,vars.EdgeSnap))
					Overlay.CFrame = tcf*JointCenter
					SelectEdgeVisible = true
				else
					SelectEdgeVisible = false
					OverlayArcHandles.Visible = false
					OverlayGUIParent(nil)
				end
			end
			
			local emb1, emmv = Enum.UserInputType.MouseButton3, Enum.UserInputType.MouseMovement
			
			Event.SelectEdge.Down = InputService.InputBegan:Connect(function(input, gpe)
				if input.UserInputType == emb1 then
					Down = true
					if IsAltDown() then
						select_edge()
					end
				end
			end)
			
			Event.SelectEdge.Up = InputService.InputEnded:Connect(function(input, gpe)
				if input.UserInputType == emb1 then
					OverlayArcHandles.Visible = true
					OverlaySelectionBox.Visible = false
					-- Overlay.Size = v3(4, 4, 4)
					SelectEdgeUpdateOverlay()
					Down = false
	
					Event.SelectEdge.SelectHold = nil
				end
			end)
			
			Event.SelectEdge.Move = InputService.InputChanged:Connect(function(input, gpe)
				if input.UserInputType == emmv then
					click_stamp = 0
					if Down then
						if IsAltDown() then
							select_edge()
						else
							OverlayArcHandles.Visible = true
							OverlaySelectionBox.Visible = false
							-- Overlay.Size = v3(4, 4, 4)
							SelectEdgeUpdateOverlay()
						end
					end
				end
			end)

			local inc = 0
			local ocf = cf()
			local origin = {}
			local modelOrigin = {}
			local corigin = cf()
			local rdis

			Event.SelectEdge.Arc.Down = OverlayArcHandles.MouseButton1Down:Connect(function(axis)
				if SelectEdgeVisible then
					inc = vars.RotIncrement
					corigin = Overlay.CFrame
					for k in next,origin do
						origin[k] = nil
					end
					for k in next,modelOrigin do
						modelOrigin[k] = nil
					end
					for _,part in next,ToolSelection do
						origin[part] = corigin:toObjectSpace(part.CFrame)
					end
					pcall(function()
						for _,model in next,ToolModelSelection do
							modelOrigin[model] = corigin:toObjectSpace(model:GetPivot())
						end
					end)
					ocf = corigin:toObjectSpace(Overlay.CFrame)
					DisplayInfo(true, 'Rotate',0)
				end
			end)
			
			Event.SelectEdge.Arc.Drag = OverlayArcHandles.MouseDrag:Connect(function(axis, angle)
				rdis = Snap(deg(nmin(angle%tau,angle%-tau)),inc)
				local a = faxis(axis)*rad(rdis)
				local new = corigin*CFrame.Angles(a.x,a.y,a.z)
				for part,cframe in next,origin do
					part.CFrame = new:toWorldSpace(cframe)
				end
				for model,pivot in next,modelOrigin do
					model.WorldPivot = new:toWorldSpace(pivot)
				end
				Overlay.CFrame = new:toWorldSpace(ocf)
				DisplayInfo(false, 'Rotate',rdis)
			end)

			Event.SelectEdge.Arc.Up = OverlayArcHandles.MouseButton1Up:Connect(function(axis,angle)
				DisplayInfo(true, 'Rotated',rdis)
			end)
		end

		OnSelectionChanged[Tool] = function(tool,vars)
			ToolSelection, ToolModelSelection = GetPartsAndModels(Selection:Get())
			SelectEdgeUpdateOverlay()
		end

		OnToolDeselect[Tool] = function(tool,vars)
			Event.SelectEdge = nil
			OverlayGUIParent(nil)
			OverlaySelectionBox.Visible = false
			OverlayArcHandles.Visible = false
		end
	end
end


local ParametricEval do
	local s_env = assert(mathEnv.env)
	local s_help = assert(mathEnv.help)
	local tonumber = tonumber
	
	local LOADSTRING_ENABLED = pcall(loadstring, "")
	
	local env_mt = {
		__metatable = false,
		__index = function(_, k)
			PluginWarn(('%s is undefined.'):format(tostring(k)))
		end,
	}
	
	local function Parse(str, env)
		local f = loadstring(('return (%s)'):format(str))
		if f then
			setfenv(f, env)
			local s, r = pcall(f)
			if s then
				return r
			else
				PluginWarn(('Parametric evaluation failed.\nInput: %s\nError: %s'):format(tostring(str), tostring(r)))
			end
		end
	end
	
	function ParametricEval(str, lastVal)
		local r = tonumber(str)

		if r then
			return r
		end
		
		if not LOADSTRING_ENABLED then
			PluginWarn("Parametric evaluation is disabled.")
			return nil
		end
			
		if str:lower() == 'help' then
			print(s_help)
		else
			local env = {}
			for k, v in next, s_env do
				env[k] = v ~= 'prev' and v or lastVal
			end
			setmetatable(env, env_mt)

			local r = Parse(str, env)

			if r and tonumber(r) then
				return tonumber(r)

			elseif r ~= nil then
				PluginWarn("Parametric output is not a number.")
				return nil
			end
		end
	end
end

local Screen

local GUI_Initialized = false
local GUI_Active = false

local SetHoverAreaEnabled

local ExpandPanel
local CollapsePanel

local toolNameToBox = {}
local toolNameToIncrement = {}

local function InitializeGUI()
	CoreRoot = Instance.new('Folder')
	CoreRoot.Name = 'sbs'
	CoreRoot.Parent = CoreGui
	
	plugin.Unloading:Connect(function()
		CoreRoot:Destroy()
	end)

	local draggingMenu = false
	local infoRight = false
	local hoverEnabled = true
	local panelPosition
	local collapseAxis = 'x'
	local collapseDirection = -1
	
	local GlobalStylist = gloo.Stylist{
		Font = 'SourceSans';
		TextSize = 14;
		TextColor3 = rgb(255,255,255);
	}
	-- Menu containers
	local MenuStylist = gloo.Stylist{
		BackgroundTransparency = 1;
		BackgroundColor3 = rgb(0,0,0);
		BorderColor3 = rgb(255,255,255);
		BorderSizePixel = 0;
	}
	-- Button default
	local ButtonStylist = gloo.Stylist{
		BackgroundTransparency = 1;
		BackgroundColor3 = rgb(0,0,0);
		BorderColor3 = rgb(255,255,255);
		Size = ud2(0,100,0,20);
		BorderSizePixel = 0;
		TextStrokeTransparency = 0.93;
		AutoButtonColor = false;
		ZIndex = 2;
	}
	GlobalStylist.AddStylist(ButtonStylist)
	-- Selected tool
	local SelectedButtonStylist = gloo.Stylist{
		BackgroundTransparency = 1;
		BackgroundColor3 = rgb(0,0,0);
		BorderColor3 = rgb(255,255,255);
		Size = ud2(0,100,0,18);
		BorderSizePixel = 1;
		TextStrokeTransparency = 0.9;
		ZIndex = 2;
	}
	GlobalStylist.AddStylist(SelectedButtonStylist)
	-- Menu headers
	local MenuNodeStylist = gloo.Stylist{
		BackgroundTransparency = 0;
		BorderSizePixel = 0;
		Size = ud2(0,100,0,8);
		ZIndex = 2;
	}
	local HoverNameStylist = gloo.Stylist{
		BackgroundTransparency = 1;
		TextStrokeColor3 = rgb(0,0,0);
		TextStrokeTransparency = 0.9;
		ZIndex = 1;
	}
	GlobalStylist.AddStylist(HoverNameStylist)

	local DockClass = gloo.DockContainer()
	Screen = DockClass.GUI
	Screen.Name = 'Panel'
	Screen.AutoLocalize = false
	Screen.Enabled = false

	DisplayInfoGUI = Create('TextButton',{
		Name = 'DisplayInfoGUI';
		Text = '';
		Parent = Screen;
	})
	HoverNameStylist.AddObject(DisplayInfoGUI)

	local InfoClass = gloo.AutoSizeLabel(DisplayInfoGUI)
	InfoClass.LockAxis(nil,24)
	InfoClass.SetPadding(4)

	local MenuContainerClass, MenuContainerFrame = gloo.StackingFrame(inst'ImageButton')
	MenuContainerClass.SetPadding(4, 8)
	Modify(MenuContainerFrame, {
		AutoButtonColor = false;
		Name = 'MenuContainer';
		BorderSizePixel = 0;
		BackgroundColor3 = rgb(68, 68, 68);
		BackgroundTransparency = 0;
		Position = ud2(0,0,0,24);
		Parent = Screen;
	})
	panelPosition = MenuContainerFrame.Position

	local Placeholder = Create('Frame', {
		Name = 'Placeholder';
		BackgroundTransparency = 1;
	})
	
	local MouseDrag = Create('ImageButton', {
		Active = false;
		Size = ud2(1.5, 0, 1.5, 0);
		AutoButtonColor = false;
		BackgroundTransparency = 1;
		Name = 'MouseDrag';
		Position = ud2(-0.25, 0, -0.25, 0);
		ZIndex = 10;
	})

	local MouseOverFrame = Create('Frame', {
		Name = 'MouseOver';
		BackgroundTransparency = 1;
		Parent = Screen;
	})

	local function GetPosIndex(list,pos,size)
		list = MenuContainerClass.List
		if #list > 1 then
			local yMax = pos.y
			local index
			for i, menu in next,list do
				local ypos = menu.AbsolutePosition.y
				if ypos + menu.AbsoluteSize.y/2 > yMax - size.y and ypos + size.y > yMax - size.y then
					index = i
					break
				end
			end
			return index
		else
			return 1
		end
	end

	local function InvokeMenuDrag(MenuFrame,offset,fToggle)
		draggingMenu = true

		local orderSet = {}
		for i, v in ipairs(MenuContainerClass.List) do
			orderSet[i] = v.AbsolutePosition + v.AbsoluteSize/2
		end

		local mouse_pos = offset + MenuFrame.AbsolutePosition
		Placeholder.Size = MenuFrame.Size
		local index = MenuContainerClass.GetIndex(MenuFrame)
		MenuContainerClass.RemoveObject(MenuFrame)
		MenuContainerClass.AddObject(Placeholder,index)
		MenuFrame.Parent = Screen

		local drag_con
		local up_con

		local doToggle = true
		
		
		local zRefs = {[MenuFrame] = MenuFrame.ZIndex}
		local function r_addZRef(obj)
			for _, v in next, Children(obj) do
				if IsA(v, 'GuiObject') then
					zRefs[v] = v.ZIndex
				end
				r_addZRef(v)
			end
		end
		r_addZRef(MenuFrame)
		local zOffset = 5
		for obj, z in next, zRefs do
			obj.ZIndex = z + zOffset
		end
		
		
		local function mouse_up()
			for obj, z in next,zRefs do
				obj.ZIndex = z
			end
			MouseDrag.Parent = nil
			drag_con:Disconnect(); drag_con = nil
			up_con:Disconnect();
			MenuContainerClass.RemoveObject(Placeholder)
			MenuContainerClass.AddObject(MenuFrame,index)
			draggingMenu = false
			if doToggle then
				fToggle()
			end
		end

		local function mouse_drag(x,y)
			local pos = v2(x,y) - offset
			local x,y = pos.x,pos.y
			local cPos = MenuContainerFrame.AbsolutePosition + v2(8, 8)
			local max = cPos + MenuContainerFrame.AbsoluteSize - v2(16, 16)

			if y > max.y then
				y = max.y
			elseif y < cPos.y then
				y = cPos.y
			end

			MenuFrame.Position = ud2(0,cPos.x,0,y)
			local _index = GetPosIndex(
				orderSet,
				MenuFrame.AbsolutePosition + MenuFrame.AbsoluteSize/2,MenuFrame.AbsoluteSize/2
			) or index
			if index ~= _index then
				index = _index
				MenuContainerClass.MoveObject(Placeholder,index)
			end
		end

		drag_con = MouseDrag.MouseMoved:Connect(function(...)
			doToggle = false
			mouse_drag(...)
		end)
		up_con = MouseDrag.MouseButton1Up:Connect(mouse_up)
		MouseDrag.Parent = Screen
		mouse_drag(mouse_pos.x,mouse_pos.y)
	end
	
	for i = 1, #MenuList do
		local menu_name = MenuList[i]
		local menu = Menus[menu_name]
		local MenuClass,MenuFrame = gloo.StackingFrame()
		MenuClass.SetPadding()
		MenuStylist.AddObject(MenuFrame)
		MenuContainerClass.AddObject(MenuFrame)
		
		do
			local groupColor = menu.Color or rgb(255, 255, 255)
			
			local Node = inst('ImageButton')
			Node.BackgroundColor3 = groupColor
			MenuNodeStylist.AddObject(Node)
			MenuClass.AddObject(Node)
			Node.ZIndex = 2
			Node.AutoButtonColor = false
			local shadow = Create('Frame', {
				Parent = Node;
				BackgroundColor3 = rgb(0,0,0);
				BackgroundTransparency = 0.7;
				BorderSizePixel = 0;
				Size = ud2(1, 0, 0, 2);
				Position = ud2(0, 0, 1, -2);
				ZIndex = 2;
			})
			local active = true
			
			Node.MouseEnter:Connect(function()
				Node.ZIndex = 2
				shadow.ZIndex = 2
				Node.BackgroundColor3 = Saturate(groupColor, 32)
			end)
			
			Node.MouseLeave:Connect(function()
				Node.ZIndex = 2
				shadow.ZIndex = 2
				Node.BackgroundColor3 = groupColor
			end)

			local visible = true
			local function toggle_menu()
				visible = not visible
				for i,button in next,MenuClass.List do
					if button ~= Node then
						button.Visible = visible
					end
				end
			end

			Node.MouseButton1Down:Connect(function(x,y)
				InvokeMenuDrag(MenuFrame,v2(x,y) - MenuFrame.AbsolutePosition,toggle_menu)
				Node.ZIndex = 2
				shadow.ZIndex = 2
			end)
		end
		local vars = menu.Variables
		
		local textBoxOverlays = Children(path_ui.Textbox)
		local buttonOverlays = Children(path_ui.Button)
		local numVars = 0
		for _, v in next, menu.VariableList do
			numVars = numVars + 1
		end
		for i,var in next, menu.VariableList do
			local name = var[1]
			local field
			if type(vars[name]) == 'number' then
				vars[name] = plugin:GetSetting('Menus/' .. menu_name .. '/Variables/' .. name) or vars[name]
				field = inst('TextBox')
				ButtonStylist.AddObject(field)
				MenuClass.AddObject(field)
				field.Text = vars[name]
				
				field.FocusLost:Connect(function(enter)
					field.overlay_active.Visible = false
					field.overlay_inactive.Visible = true
					local num = ParametricEval(field.Text, vars[name])
					if num then
						vars[name] = num
						plugin:SetSetting('Menus/' .. menu_name .. '/Variables/' .. name, num)
						field.Text = num
					else
						field.Text = vars[name]
					end
				end)
			elseif type(vars[name]) == 'string' then
				field = inst'TextBox'
				ButtonStylist.AddObject(field)
				MenuClass.AddObject(field)
				field.Text = vars[name]
				
				field.FocusLost:Connect(function(enter)
					field.overlay_active.Visible = false
					field.overlay_inactive.Visible = true
					if field.Text ~= '' then
						vars[name] = field.Text
					else
						field.Text = vars[name]
					end
				end)
			end
			if field then
				if numVars == 1 or var[1] == 'RotIncrement' then
					menu.Box = field
				end
				for _, overlay in next, textBoxOverlays do
					local g = Clone(overlay)
					g.Visible = false
					g.Parent = field
				end
				field.overlay_inactive.Visible = true
				field.Focused:Connect(function()
					field.overlay_active.Visible = true
					field.overlay_inactive.Visible = false
				end)
			end
		end
		
		for _, menu in next, Menus do
			if menu.Box then
				for _, toolName in next, menu.Tools do
					toolNameToBox[toolName] = menu.Box
					toolNameToIncrement[toolName] = menu.Variables
				end
			end
		end
		
		for i,tool in next, menu.Tools do
			local isSelected = false
			local hover = false
			
			local button = inst('TextButton')
			ButtonStylist.AddObject(button)
			button.Name = tool
			button.Text = tool
			for _, overlay in next, buttonOverlays do
				local g = Clone(overlay)
				g.Visible = false
				g.Parent = button
			end
			MenuClass.AddObject(button)
			
			local istates = {
				hover   = button.overlay_hover;
				active  = button.overlay_active;
				standby = button.overlay_inactive;
			}
			
			local function SetState(state)
				(istates[state] or PluginErr'Invalid hover state').Visible = true
				for i, v in next, istates do
					if i ~= state then
						v.Visible = false
					end
				end
			end	
			
			
			ToolSelectCallback[tool] = function()
				isSelected = true
				SetState'active'
			end
			
			ToolDeselectCallback[tool] = function()
				isSelected = false
				if hover then
					SetState'hover'
				else
					SetState'standby'
				end
			end
			
			button.MouseButton1Click:Connect(function()
				SelectTool(tool)
			end)
			
			button.MouseEnter:Connect(function()
				hover = true
				if not isSelected then
					SetState'hover'
				end
			end)
			
			button.MouseLeave:Connect(function()
				hover = false
				if not isSelected then
					SetState'standby'
				end
			end)
			
			SetState'standby'
		end
	end


	local function TweenPanel(position)
		spr.target(MenuContainerFrame, 1, 9, {Position = position})
	end

	function ExpandPanel()
		if hoverEnabled and collapseDirection ~= 0 then
			DisplayInfoGUI.Visible = true
			if collapseAxis == 'y' then
				if collapseDirection == 1 then
					TweenPanel(panelPosition)
				else
					local x = panelPosition.X
					TweenPanel(ud2(x.Scale, x.Offset, 0, 0))
				end
			else
				if collapseDirection == 1 then
					TweenPanel(panelPosition)
				else
					local y = panelPosition.Y
					TweenPanel(ud2(0, 0, y.Scale, y.Offset))
				end
			end
		end
	end

	function CollapsePanel()
		if hoverEnabled and collapseDirection ~= 0 and not SelectedTool and not draggingMenu then
			DisplayInfoGUI.Visible = false
			if collapseAxis == 'y' then
				local x = panelPosition.X
				if collapseDirection == 1 then
					TweenPanel(ud2(x.Scale, x.Offset, 1, 0))
				else
					TweenPanel(ud2(x.Scale, x.Offset, 0, -MenuContainerFrame.AbsoluteSize.y))
				end
			else
				local y = panelPosition.Y
				if collapseDirection == 1 then
					TweenPanel(ud2(1, 0, y.Scale, y.Offset))
				else
					TweenPanel(ud2(0, -MenuContainerFrame.AbsoluteSize.x, y.Scale, y.Offset))
				end
			end
		end
	end
	
	SetHoverAreaEnabled = function(enabled)
		MouseOverFrame.Visible = enabled
	end

	MouseOverFrame.MouseEnter:Connect(ExpandPanel)
	MouseOverFrame.MouseLeave:Connect(CollapsePanel)

	MenuContainerFrame.Changed:Connect(function(p)
		if hoverEnabled and p == 'AbsoluteSize' then
			MouseOverFrame.Size = MenuContainerFrame.Size
		end
	end)
	MouseOverFrame.Size = MenuContainerFrame.Size
	MouseOverFrame.Position = MenuContainerFrame.Position

	DisplayInfoGUI.Changed:Connect(function(p)
		if infoRight and p == 'AbsoluteSize' then
			local pos = DisplayInfoGUI.Position
			DisplayInfoGUI.Position = ud2(1,-DisplayInfoGUI.AbsoluteSize.x,pos.Y.Scale,pos.Y.Offset)
		end
	end)

	DockClass.DragBeginCallback = function(dragged)
		if dragged == MenuContainerFrame then
			hoverEnabled = false
		end
	end

	DockClass.DragCallback = function(dragged)
		if dragged == MenuContainerFrame then
			collapseAxis = 'x'
			collapseDirection = 0
		elseif dragged == DisplayInfoGUI then
			infoRight = false
		end
	end

	DockClass.DockCallback = function(dragged,docked,axis,side)
		if dragged == MenuContainerFrame then
			collapseAxis = axis
			collapseDirection = side*2-1
		elseif dragged == DisplayInfoGUI then
			if docked == Screen and axis == 'x' and side == 1 then
				infoRight = true
			end
		end
	end

	DockClass.DragStopCallback = function(dragged)
		if dragged == MenuContainerFrame then
			panelPosition = MenuContainerFrame.Position
			MouseOverFrame.Position = panelPosition
			hoverEnabled = true
		end
	end

	GUI_Initialized = true
end


local function ActivateGUI()
	if GUI_Initialized then
		if not Mouse_Active then
			ActivateMouse()
		end
		SetHoverAreaEnabled(true)
		if ExpandPanel then
			ExpandPanel()
		end
		Screen.Enabled = true
		Screen.Parent = CoreRoot
		GUI_Active = true
	end
end


local function DeactivateGUI()
	if GUI_Initialized then
		GUI_Active = false
		DeselectTool(SelectedTool)
		SetHoverAreaEnabled(false)
		if CollapsePanel then
			CollapsePanel()
		end
		if Mouse_Active then
			DeactivateMouse()
		end
	end
end

InitializeGUI()
DeactivateGUI()

ActivateGUIButton.Click:Connect(function()
	if GUI_Initialized then
		if GUI_Active then
			DeactivateGUI()
			ActivateGUIButton:SetActive(false)
		else
			ActivateGUI()
			ActivateGUIButton:SetActive(true)
		end
	else
		InitializeGUI()
		ActivateGUI()
		ActivateGUIButton:SetActive(true)
	end
end)


ActivateMouseButton.Click:Connect(function()
	if Mouse_Active then
		ActivateMouseButton:SetActive(false)
		DeactivateMouse()
	else
		ActivateMouseButton:SetActive(true)
		ActivateMouse()
	end
end)


do
	local function Activate()
		if GUI_Initialized then
			if not GUI_Active then
				ActivateGUI()
			end
		else
			InitializeGUI()
			ActivateGUI()
		end
	end

	local function SpecialSelectTool(Tool)
		SelectTool(Tool)
		Activate()
		if SelectedTool then
			ExpandPanel(true)
		end
	end
	
	if MACROS_ACTIVE then
		local toolKeymap = {} do
			local toolDict = {
				moveAxis = Menus.Move.Tools[1],
				moveObj = Menus.Move.Tools[2],
				moveFirst = Menus.Move.Tools[3],
				rotatePivot = Menus.Rotate.Tools[1],
				rotateGroup = Menus.Rotate.Tools[2],
				rotateObj = Menus.Rotate.Tools[3],
				resizeObj = Menus.Resize.Tools[1],
				resizeCenter = Menus.Resize.Tools[2],
				resizeWorld = Menus.Resize.Tools[3],
				selectEdge = Menus.SelectEdge.Tools[1],
			}

			for key, toolName in next, TOOL_MACROS do
				if toolDict[toolName] then
					toolKeymap[Enum.KeyCode[key]] = toolDict[toolName]
				else
					PluginWarn(('Ignoring unrecognized tool macro:  {%s->%s}'):format(key, toolName))
				end
			end
		end
		
		
		local shiftActions do
			local function Duplicate() 
				for _, item in next, Selection:Get() do
					if item.Archivable then
						Clone(item).Parent = item.Parent
					else
						item.Archivable = true
						local newItem = Clone(item)
						newItem.Parent = item.Parent
						newItem.Archivable, item.Archivable = false, false
					end
				end
			end


			local function Separate()
				local u = {}
				for _, item in next, Selection:Get() do
					if IsA(item, 'UnionOperation') then
						u[#u + 1] = item
					end
				end
				if #u ~= 0 then
					DisplayInfo(true, 'Separating ' .. tostring(#u) .. ' unions')
					if not pcall(plugin.Separate, plugin, u) then
						PluginWarn('Separation failed')
					end
					DisplayInfo(true, 'Separated ' .. tostring(#u) .. ' unions')
				else
					DisplayInfo(false, 'No unions selected')
				end
			end


			shiftActions = {
				[Enum.KeyCode.Slash] = Separate;
				[Enum.KeyCode.C] = Duplicate;
			}
		end
		
		
		local singleKeyActions do
			local function DeselectAll()
				Selection:Set({})
			end
			
			local function SelectVarField()
				local box = toolNameToBox[SelectedTool]
				if box then
					box:CaptureFocus()
				end
			end
			
			local function HalveInc()
				local box = toolNameToBox[SelectedTool]
				local inc = toolNameToIncrement[SelectedTool]
				if box and inc then
					local k, n = next(inc)
					if type(n) == 'number' then
						n = n/2
						inc[k] = n
						box.Text = tostring(n)
					end
				end
			end
			
			local function DoubleInc()
				local box = toolNameToBox[SelectedTool]
				local inc = toolNameToIncrement[SelectedTool]
				if box and inc then
					local k, n = next(inc)
					if type(n) == 'number' then
						n = n*2
						inc[k] = n
						box.Text = tostring(n)
					end
				end
			end
		
			singleKeyActions = {
				[Enum.KeyCode.Escape] = DeselectAll;
				[Enum.KeyCode.Tab]    = SelectVarField;
				[Enum.KeyCode.Two]    = HalveInc;
				[Enum.KeyCode.Three]  = DoubleInc;
			}
		end
		
		
		local IsKeyDown = InputService.IsKeyDown
		local userEnum = {
			KeyCode = {
				LeftControl  = Enum.KeyCode.LeftControl;
				LeftShift    = Enum.KeyCode.LeftShift;
				RightControl = Enum.KeyCode.RightControl;
				RightShift   = Enum.KeyCode.RightShift;
			};
			UserInputType = {
				Keyboard     = Enum.UserInputType.Keyboard;
				MouseButton1 = Enum.UserInputType.MouseButton1;				
			};
		}
		
		local mouseDown = false
		
		
		local function OnKeyAction(keyCode)
			local ctrl  = IsKeyDown(InputService, userEnum.KeyCode.RightControl)
				or IsKeyDown(InputService, userEnum.KeyCode.LeftControl)
			local shift = IsKeyDown(InputService, userEnum.KeyCode.RightShift) 
				or IsKeyDown(InputService, userEnum.KeyCode.LeftShift)

			if shift and not ctrl then
				local action = shiftActions[keyCode]
				if action then
					action()
				end
			elseif not ctrl and not shift and not mouseDown then
				if toolKeymap[keyCode] then
					SpecialSelectTool(toolKeymap[keyCode])
				elseif singleKeyActions[keyCode] then
					singleKeyActions[keyCode]()
				end
			end
		end
		
		
		InputService.InputBegan:Connect(function(input, gpe)
			local inputType = input.UserInputType
			if gpe and inputType == userEnum.UserInputType.MouseButton1 then
				mouseDown = true
			elseif not gpe and GUI_Active then
				if inputType == userEnum.UserInputType.Keyboard then
					OnKeyAction(input.KeyCode)
				end
			end
		end)
		
		InputService.InputEnded:Connect(function(input)
			if input.UserInputType == userEnum.UserInputType.MouseButton1 then
				mouseDown = false
			end
		end)
	end
end]]></ProtectedString>
