local function nmin(a, b)
	return ((a < 0 and -a or a) < (b < 0 and -b or b)) and a or b
end


local MIN_SIZE do 
	local tempPart = Instance.new'Part'
	tempPart.Size = v3()
	local minSize = tempPart.Size
	tempPart:Destroy()
	MIN_SIZE = max(minSize.x, minSize.y, minSize.z)
end


local function Snap(x, inc)
	if inc ~= 0 then
		local rem = x%inc
		if 2*rem ~= inc then
			return (2*rem < inc and x or x + inc) - rem
		end
		return ((x - rem)%(2*inc) == 0 and x or x + inc) - rem
	end
	return x
end

local function class(name)
	local def = {}
	getfenv(1)[name] = def
	return function(ctor, static)
		local nctor = function(...)
			local this = {}
			if ctor then
				ctor(this, ...)
			end
			return this
		end
		getfenv(1)['Create' .. name] = nctor
		if static then
			static(def)
		end
	end
end


local function Create(class, data)
	local parent = data.Parent
	if parent then
		data.Parent = nil
	end
	local obj = inst(class)
	for i, j in next, data do
		if type(i) == 'number' then
			j.Parent = obj
		else
			obj[i] = j
		end
	end
	obj.Parent = parent
	return obj
end


local function Modify(obj, data)
	local parent = data.Parent
	if parent then
		data.Parent = nil
	end
	for i, j in next, data do
		if type(i) == 'number' then
			j.Parent = obj
		else
			obj[i] = j
		end
	end
	obj.Parent = parent
	return obj
end


CreateEventGroup = CreateEventGroup
class'EventGroup'(function(def)
	local eventContainer = {}
	local groupContainer = {}

	local methods = {
		GetEvents = function(self)
			local copy = {}
			for name,event in next,eventContainer do
				copy[name] = event
			end
			return copy
		end;
		GetGroups = function(self)
			local copy = {}
			for name,group in next,groupContainer do
				copy[name] = group
			end
			return copy
		end;
		Clear = function(self)
			for k in next,eventContainer do
				self[k] = nil
			end
			for k in next,groupContainer do
				self[k] = nil
			end
		end;
	}

	setmetatable(def,{
		__index = function(t,k)
			local event = eventContainer[k]
			if event then
				return event
			else
				local group = groupContainer[k]
				if not group then
					group = CreateEventGroup()
					groupContainer[k] = group
				end
				return group
			end
		end;
		__newindex = function(t,k,v)
			local event = eventContainer[k]
			if event ~= nil then
				if event.Disconnect then
					event:Disconnect()
				end
				eventContainer[k] = nil
			else
				local group = groupContainer[k]
				if group ~= nil then
					group('Clear')
					groupContainer[k] = nil
				end
			end
			if v ~= nil then
				eventContainer[k] = v
			end
		end;
		__call = function(self,name,...)
			if methods[name] then
				return methods[name](self,...)
			else
				error('EventGroup: '..tostring(name)..' is not a valid method',2)
			end
		end;
	})
end)

local Event = CreateEventGroup()

local Saturate do
	local function hue2rgb(p, q, t)
		if t < 0 then
			t = t + 1
		elseif t > 1 then
			t = t - 1
		end

		if t < 1/6 then
			return p + (q - p)*6*t
		elseif t < 1/2 then
			return q
		elseif t < 2/3 then
			return p + (q - p)*(2/3 - t)*6
		end

		return p
	end
	
	local function hsl2Rgb(h, s, l)
		local r, g, b
		if s == 0 then
			r,g,b = l,l,l
		else
			local q
			if l < 1/2 then
				q = l*(1 + s)
			else
				q = l + s - l*s
			end
			local p = 2*l - q
			r = hue2rgb(p, q, h + 1/3)
			g = hue2rgb(p, q, h)
			b = hue2rgb(p, q, h - 1/3)
		end
		return Color3.new(r, g, b)
	end
	
	local function rgb2Hsl(r, g, b)
		local max, min = max(r, g, b), min(r, g, b)
		local h, s
		local l = (max + min)/2
		if max == min then
			h, s = 0, 0
		else
			local d = max - min
			if l > 1/2 then
				s = d/(2 - max - min)
			else
				s = d/(max + min)
			end
			if max == r then
				local e
				if g < b then
					e = 6
				else
					e = 0
				end
				h = (g - b)/d + e
			elseif max == g then
				h = (b - r)/d + 2
			elseif max == b then
				h = (r - g)/d + 4
			end
			h = h/6
		end
		return h, s, l
	end
	
	function Saturate(color, a)
		local h, s, l = rgb2Hsl(color.r, color.g, color.b)
		return hsl2Rgb(h, s, l + a/255)
	end
end

local function GetPartsAndModels(t)
	local partSet = {}
	local modelSet = {}

	for i = 1, #t do
		local obj = t[i]
		if IsA(obj, 'BasePart') then
			partSet[obj] = true
		elseif IsA(obj, 'Model') then
			modelSet[obj] = true
		end

		for _, desc in pairs(obj:GetDescendants()) do
			if IsA(desc, 'BasePart') then
				partSet[desc] = true
			elseif IsA(desc, 'Model') then
				modelSet[desc] = true
			end
		end
	end

	local partArr = {}
	local n_partArr = 0

	for part in pairs(partSet) do
		n_partArr = n_partArr + 1
		partArr[n_partArr] = part
	end
	
	local modelArr = {}
	local n_modelArr = 0

	for model in pairs(modelSet) do
		n_modelArr = n_modelArr + 1
		modelArr[n_modelArr] = model
	end

	return partArr, modelArr
end

local function GetPartsSingleParent(root)
	local partArr = {IsA(root, 'BasePart') and root or nil}
	local n_partArr = #partArr

	for _, desc in pairs(root:GetDescendants()) do
		if IsA(desc, 'BasePart') then
			n_partArr = n_partArr + 1
			partArr[n_partArr] = desc
		end
	end

	return partArr
end

local RecurseGetBoundingBox do
	local bb_points = {
		v3(-1/2, -1/2, -1/2),
		v3( 1/2, -1/2, -1/2),
		v3(-1/2,  1/2, -1/2),
		v3( 1/2,  1/2, -1/2),
		v3(-1/2, -1/2,  1/2),
		v3( 1/2, -1/2,  1/2),
		v3(-1/2,  1/2,  1/2),
		v3( 1/2,  1/2,  1/2),
	}

	function RecurseGetBoundingBox(object, sides, parts)
		local s1, s2, s3, s4, s5, s6 = sides[1], sides[2], sides[3], sides[4], sides[5], sides[6]
		local pn = parts and #parts
		local objs = GetPartsSingleParent(object)
		for i = 1, #objs do
			local obj = objs[i]
			local mod, rot = obj.Size, obj.CFrame
			for i = 1, 8 do
				local vert = rot*cf(bb_points[i]*mod).p
				local x, y, z = vert.x, vert.y, vert.z
				if x > s1 then sides[1], s1 = x, x end
				if x < s2 then sides[2], s2 = x, x end
				if y > s3 then sides[3], s3 = y, y end
				if y < s4 then sides[4], s4 = y, y end
				if z > s5 then sides[5], s5 = z, z end
				if z < s6 then sides[6], s6 = z, z end
			end
			if parts then
				pn = pn + 1
				parts[pn] = obj
			end
		end
	end
end


local function GetBoundingBox(objects, return_parts)
	local sides = {-inf, inf, -inf, inf, -inf, inf}
	local parts = return_parts and {} or nil
	for i = 1, #objects do
		RecurseGetBoundingBox(objects[i], sides, parts)
	end
	return
		v3(sides[1] - sides[2], sides[3] - sides[4], sides[5] - sides[6]),
		v3((sides[1] + sides[2])/2, (sides[3] + sides[4])/2, (sides[5] + sides[6])/2),
		parts
end

local disp_dec = 10^5
local DisplayInfoGUI
local function DisplayInfo(DoSetWaypoint, ...)
	if DisplayInfoGUI then
		local NewText = ''
		for _, arg in next, {...} do
			NewText = ('%s%s '):format(NewText, tostring(
				type(arg) ~= 'number' and arg or floor(abs(arg)*disp_dec + 0.5)/disp_dec
			))
		end
		if DisplayInfoGUI.Text ~= NewText then
			DisplayInfoGUI.Text = NewText
			if DoSetWaypoint then
				HistoryService:SetWaypoint(('SBS [%s] @%.3f'):format(NewText, tick()))
			end
		end
	end
end

